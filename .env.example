# Required — PostgreSQL connection string
# Examples:
#   postgresql://user:password@localhost:5432/hiking_club
#   postgres://postgres:postgres@localhost:5432/hiking_club
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hiking_club

# Optional — defaults to 5000
PORT=5000

# Optional — set to "production" when running `npm start`
NODE_ENV=development
